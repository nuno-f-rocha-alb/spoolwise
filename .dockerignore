# VCS / tooling
.git
.gitignore
.claude

# Frontend deps + build artifacts — the SPA is built fresh inside the image's
# Node stage, then copied into app/spa, so none of these belong in the context.
frontend/node_modules
frontend/dist
app/spa

# Python caches / local envs
**/__pycache__
*.pyc
.venv
venv
.env
.env.*

# Repo extras not needed in the image
docs
graphify-out
app/graphify-out
